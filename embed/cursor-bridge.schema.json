    "goclaw": {
      "detectHeaders": [
        "x-goclaw-session",
        "x-goclaw-agent",
        "user-agent:goclaw"
      ],
      "tools": {
        "edit": {
          "required": [
            "path",
            "old_string",
            "new_string"
          ],
          "aliases": [
            "search_replace",
            "StrReplace"
          ],
          "coercions": [
            {
              "when": {
                "has": [
                  "path",
                  "edits"
                ],
                "missing": [
                  "old_string"
                ]
              },
              "from": {
                "path": "$path",
                "edits": "$edits"
              },
              "to": {
                "path": "$path",
                "old_string": "$edits[0].oldText",
                "new_string": "$edits[0].newText"
              }
            }
          ]
        },
        "apply_patch": {
          "required": [
            "patch"
          ],
          "aliases": [
            "apply_patch"
          ],
          "coercions": [
            {
              "when": {
                "has": [
                  "input"
                ],
                "missing": [
                  "patch"
                ]
              },
              "from": {
                "input": "$input"
              },
              "to": {
                "patch": "$input"
              }
            }
          ]
        },
        "read_file": {
          "required": [
            "path"
          ],
          "aliases": [
            "read",
            "Read",
            "read_file"
          ],
          "coercions": [
            {
              "when": {
                "has": [
                  "file_path"
                ],
                "missing": [
                  "path"
                ]
              },
              "from": {
                "file_path": "$file_path"
              },
              "to": {
                "path": "$file_path"
              }
            },
            {
              "when": {
                "has": [
                  "target_file"
                ],
                "missing": [
                  "path"
                ]
              },
              "from": {
                "target_file": "$target_file"
              },
              "to": {
                "path": "$target_file"
              }
            },
            {
              "when": {
                "has": [
                  "target"
                ],
                "missing": [
                  "path"
                ]
              },
              "from": {
                "target": "$target"
              },
              "to": {
                "path": "$target"
              }
            }
          ]
        },
        "write": {
          "required": [
            "path",
            "content"
          ],
          "aliases": [
            "Write",
            "write"
          ],
          "coercions": [
            {
              "when": {
                "has": [
                  "file_path"
                ],
                "missing": [
                  "path"
                ]
              },
              "from": {
                "file_path": "$file_path"
              },
              "to": {
                "path": "$file_path"
              }
            },
            {
              "when": {
                "has": [
                  "contents"
                ],
                "missing": [
                  "content"
                ]
              },
              "from": {
                "contents": "$contents"
              },
              "to": {
                "content": "$contents"
              }
            }
          ]
        },
        "exec": {
          "required": [
            "command"
          ],
          "aliases": [
            "run_terminal_cmd",
            "bash",
            "shell",
            "grep",
            "glob",
            "glob_file_search"
          ]
        }
      }
    }
