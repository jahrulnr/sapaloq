{
  "schemaVersion": "1.0.5",
  "provider": {
    "id": "cursor",
    "nativeTools": [
      "Apply Patch",
      "StrReplace",
      "apply_patch",
      "ask_question",
      "codebase_search",
      "delete_file",
      "edit_file",
      "edit_notebook",
      "fetch_mcp_resource",
      "file_search",
      "glob_file_search",
      "grep",
      "list_dir",
      "list_mcp_resources",
      "memory_search",
      "read_file",
      "read_lints",
      "run_terminal_cmd",
      "search_replace",
      "update_memory",
      "web_search",
      "write"
    ],
    "sessionNonTriggerTools": [
      "ask_question",
      "update_memory"
    ],
    "aliases": {
      "bash": "run_terminal_cmd",
      "shell": "run_terminal_cmd",
      "glob": "glob_file_search",
      "strreplace": "search_replace",
      "str_replace": "search_replace",
      "applypatch": "apply_patch",
      "read": "read_file",
      "write": "write",
      "delete": "delete_file",
      "semanticsearch": "codebase_search",
      "websearch": "web_search",
      "askquestion": "ask_question",
      "listmcpresources": "list_mcp_resources",
      "fetchmcpresource": "fetch_mcp_resource",
      "editnotebook": "edit_notebook",
      "readlints": "read_lints"
    },
    "leakMarkers": [
      "input_schema",
      "Daftar schema tools",
      "Tools edit / terminal",
      "tools tersedia",
      "schema tools",
      "schema lengkap",
      "**parameters",
      "\"required\": ["
    ],
    "leakPatterns": [
      "tools?\\s+tersedia",
      "schema\\s+(tools?|lengkap)",
      "\\*\\*parameters",
      "\"required\"\\s*:\\s*\\[",
      "input_schema",
      "Daftar schema tools",
      "Tools edit / terminal"
    ],
    "kimiTokens": [
      "<|tool_calls_begin|>",
      "<|tool_calls_end|>",
      "<｜tool▁calls▁begin｜>",
      "<｜tool▁calls▁end｜>",
      "<|tool_call_begin|>",
      "<|tool_call_end|>",
      "<|tool_calls_section_begin|>",
      "<｜tool▁call▁begin｜>",
      "<｜tool▁call▁end｜>",
      "<|tool_sep|>",
      "<｜tool▁sep｜>",
      "<|tool_call_argument_begin|>"
    ],
    "toolCatalog": {
      "codebase_search": {
        "description": "Semantic search in the codebase.",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string"
            },
            "target_directory": {
              "type": "string"
            }
          },
          "required": [
            "query"
          ]
        },
        "source": "json_fence"
      },
      "run_terminal_cmd": {
        "description": "PROPOSE a command to run on behalf of the user.",
        "parameters": {
          "type": "object",
          "properties": {
            "command": {
              "type": "string"
            },
            "is_background": {
              "type": "boolean"
            }
          },
          "required": [
            "command",
            "is_background"
          ]
        },
        "source": "json_fence"
      },
      "grep": {
        "description": "Ripgrep search.",
        "parameters": {
          "type": "object",
          "properties": {
            "pattern": {
              "type": "string"
            }
          },
          "required": [
            "pattern"
          ]
        },
        "source": "json_fence"
      },
      "read_file": {
        "description": "Read a file from the filesystem. Optional offset/limit for large files. Can read image files (jpeg, png, gif, webp).",
        "parameters": {
          "type": "object",
          "properties": {
            "target_file": {
              "type": "string",
              "description": "Path to the file."
            },
            "offset": {
              "type": "integer",
              "description": "Line number to start reading from."
            },
            "limit": {
              "type": "integer",
              "description": "Number of lines to read."
            }
          },
          "required": [
            "target_file"
          ]
        },
        "source": "json_fence"
      },
      "list_mcp_resources": {
        "description": "List available resources from configured MCP servers. Optionally filter by server.",
        "parameters": {
          "type": "object",
          "properties": {
            "server": {
              "type": "string",
              "description": "Optional server identifier to filter resources."
            }
          },
          "required": []
        },
        "source": "json_fence"
      },
      "fetch_mcp_resource": {
        "description": "Read a specific resource from an MCP server by server name and resource URI.",
        "parameters": {
          "type": "object",
          "properties": {
            "server": {
              "type": "string",
              "description": "MCP server identifier."
            },
            "uri": {
              "type": "string",
              "description": "Resource URI to read."
            },
            "downloadPath": {
              "type": "string",
              "description": "Optional path to save resource to disk instead of returning content."
            }
          },
          "required": [
            "server",
            "uri"
          ]
        },
        "source": "json_fence"
      },
      "ask_question": {
        "description": "Collect structured multiple-choice answers from the user. Provide one or more questions with options, and set allow_multiple when multi-select is appropriate.\n\nUse this tool when you need to gather specific information from the user through a structured question format. Each question should have: a unique id (used to match answers); a clear prompt/question text; at least 2 options for the user to choose from; an optional allow_multiple flag (defaults to false for single-select). By default, the tool will present the questions to the user and wait for their responses before continuing. Option labels should not start with letters or numbers like \"A.\", \"1.\", or \"B -\"; the UI adds choice markers.\n\nPrefer this tool over listing options in your response text (as letters, numbers, bullet points, etc.). Also use when you are blocked and need the user to choose a path forward.",
        "parameters": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "description": "Optional title for the questions form"
            },
            "questions": {
              "type": "array",
              "description": "Array of questions to present to the user",
              "minItems": 1,
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Unique identifier for this question (used to match answers)"
                  },
                  "prompt": {
                    "type": "string",
                    "description": "The question text to display to the user, without the options."
                  },
                  "options": {
                    "type": "array",
                    "description": "Array of options for this question",
                    "minItems": 2,
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "description": "Unique identifier for this option (used in the result)"
                        },
                        "label": {
                          "type": "string",
                          "description": "Display text for this option"
                        }
                      },
                      "required": [
                        "id",
                        "label"
                      ]
                    }
                  },
                  "allow_multiple": {
                    "type": "boolean",
                    "description": "If true, user can select multiple options. If false, only one option can be selected.",
                    "default": false
                  }
                },
                "required": [
                  "id",
                  "prompt",
                  "options"
                ]
              }
            }
          },
          "required": [
            "questions"
          ]
        },
        "source": "json_fence"
      },
      "file_search": {
        "description": "",
        "parameters": null,
        "source": "inline"
      },
      "glob_file_search": {
        "description": "Search for files by glob pattern. Returns paths sorted by modification time. Patterns auto-prepended with **/ if needed.",
        "parameters": {
          "type": "object",
          "properties": {
            "glob_pattern": {
              "type": "string",
              "description": "Glob pattern (e.g. \"*.js\", \"**/test/**/test_*.ts\")."
            },
            "target_directory": {
              "type": "string",
              "description": "Directory to search; defaults to workspace root."
            }
          },
          "required": [
            "glob_pattern"
          ]
        },
        "source": "json_fence"
      },
      "list_dir": {
        "description": "List files and directories in a path. Can use ignore_globs to filter.",
        "parameters": {
          "type": "object",
          "properties": {
            "target_directory": {
              "type": "string",
              "description": "Path to directory to list."
            },
            "ignore_globs": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Glob patterns to ignore."
            }
          },
          "required": [
            "target_directory"
          ]
        },
        "source": "json_fence"
      },
      "web_search": {
        "description": "Search the web for real-time information (documentation, current events, technology updates, etc.).",
        "parameters": {
          "type": "object",
          "properties": {
            "search_term": {
              "type": "string",
              "description": "The search term to look up on the web. Be specific; include version numbers or dates when relevant."
            },
            "explanation": {
              "type": "string",
              "description": "One sentence explanation as to why this tool is being used."
            }
          },
          "required": [
            "search_term"
          ]
        },
        "source": "json_fence"
      },
      "delete_file": {
        "description": "Delete a file at the specified path. Fails gracefully if the file does not exist or cannot be deleted.",
        "parameters": {
          "type": "object",
          "properties": {
            "target_file": {
              "type": "string",
              "description": "The path of the file to delete."
            },
            "explanation": {
              "type": "string",
              "description": "One sentence explanation as to why this tool is being used."
            }
          },
          "required": [
            "target_file"
          ]
        },
        "source": "json_fence"
      },
      "edit_notebook": {
        "description": "Edit a Jupyter notebook cell. Supports replace, insert, delete. Cell indices are 0-based. Prefer editing existing cells over creating new ones.",
        "parameters": {
          "type": "object",
          "properties": {
            "target_notebook": {
              "type": "string",
              "description": "Path to the notebook file."
            },
            "cell_idx": {
              "type": "number",
              "description": "0-based cell index."
            },
            "is_new_cell": {
              "type": "boolean",
              "description": "If true, insert new cell at index; if false, edit existing cell."
            },
            "cell_language": {
              "type": "string",
              "enum": [
                "python",
                "markdown",
                "javascript",
                "typescript",
                "r",
                "sql",
                "shell",
                "raw",
                "other"
              ],
              "description": "Language of the cell."
            },
            "old_string": {
              "type": "string",
              "description": "Text to replace; must be unique in the cell when editing."
            },
            "new_string": {
              "type": "string",
              "description": "New content (or empty when deleting)."
            }
          },
          "required": [
            "target_notebook",
            "cell_idx",
            "is_new_cell",
            "cell_language",
            "old_string",
            "new_string"
          ]
        },
        "source": "json_fence"
      },
      "read_lints": {
        "description": "Read linter errors/warnings for workspace files. Optionally scope to specific paths or directories.",
        "parameters": {
          "type": "object",
          "properties": {
            "paths": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Optional list of file or directory paths. Omit for all files."
            }
          },
          "required": []
        },
        "source": "json_fence"
      },
      "search_replace": {
        "description": "Perform exact string replacements in a file. Supports replace_all. old_string must be unique unless replace_all is true.",
        "parameters": {
          "type": "object",
          "properties": {
            "file_path": {
              "type": "string",
              "description": "The path to the file to modify."
            },
            "old_string": {
              "type": "string",
              "description": "The text to replace."
            },
            "new_string": {
              "type": "string",
              "description": "The replacement text."
            },
            "replace_all": {
              "type": "boolean",
              "description": "Replace all occurrences."
            }
          },
          "required": [
            "file_path",
            "old_string",
            "new_string"
          ]
        },
        "source": "json_fence"
      },
      "update_memory": {
        "description": "Create, update, or delete a persistent memory for future conversations. Use when the user explicitly asks to remember something or forget stored information.",
        "parameters": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "create",
                "update",
                "delete"
              ],
              "description": "The action to perform."
            },
            "title": {
              "type": "string",
              "description": "Short label; required for create/update."
            },
            "knowledge_to_store": {
              "type": "string",
              "description": "Memory content; required for create/update."
            },
            "existing_knowledge_id": {
              "type": "string",
              "description": "ID of existing memory; required for update/delete."
            }
          },
          "required": []
        },
        "source": "json_fence"
      },
      "write": {
        "description": "Write or overwrite a file. Prefer editing existing files when possible. If creating a new file, include necessary imports/dependencies.",
        "parameters": {
          "type": "object",
          "properties": {
            "file_path": {
              "type": "string",
              "description": "The path to the file."
            },
            "contents": {
              "type": "string",
              "description": "The contents to write."
            }
          },
          "required": [
            "file_path",
            "contents"
          ]
        },
        "source": "json_fence"
      },
      "content": {
        "description": "",
        "parameters": null,
        "source": "inline"
      },
      "count": {
        "description": "",
        "parameters": null,
        "source": "inline"
      },
      "files_with_matches": {
        "description": "",
        "parameters": null,
        "source": "inline"
      },
      "multiline": {
        "description": "",
        "parameters": null,
        "source": "inline"
      },
      "target_directories": {
        "description": "",
        "parameters": null,
        "source": "inline"
      },
      "apply_patch": {
        "description": "",
        "parameters": null,
        "source": "inline"
      },
      "edit_file": {
        "description": "",
        "parameters": null,
        "source": "inline"
      },
      "uptime": {
        "description": "",
        "parameters": null,
        "source": "inline"
      },
      "Apply Patch": {
        "description": "",
        "parameters": null,
        "source": "nativeTools"
      },
      "StrReplace": {
        "description": "",
        "parameters": null,
        "source": "nativeTools"
      },
      "memory_search": {
        "description": "",
        "parameters": null,
        "source": "nativeTools"
      }
    }
  },
  "clients": {
    "openclaw": {
      "detectHeaders": [
        "x-openclaw-session",
        "x-openclaw-session-key",
        "x-openclaw-agent",
        "user-agent:openclaw"
      ],
      "tools": {
        "edit": {
          "required": [
            "path",
            "edits"
          ],
          "aliases": [
            "search_replace",
            "StrReplace",
            "strreplace",
            "str_replace"
          ],
          "modelGuidance": "One file per call. Example: {\"path\":\"/abs/file.md\",\"edits\":[{\"oldText\":\"foo\",\"newText\":\"bar\"}]} or path+old_string+new_string. NOT multi-file. Prefer edits[] array over stringified JSON.",
          "coercions": [
            {
              "when": {
                "has": [
                  "path",
                  "old_string",
                  "new_string"
                ],
                "missing": [
                  "edits"
                ]
              },
              "from": {
                "path": "$path",
                "old_string": "$old_string",
                "new_string": "$new_string"
              },
              "to": {
                "path": "$path",
                "edits": [
                  {
                    "oldText": "$old_string",
                    "newText": "$new_string"
                  }
                ]
              }
            },
            {
              "when": {
                "has": [
                  "file_path",
                  "old_string",
                  "new_string"
                ],
                "missing": [
                  "path",
                  "edits"
                ]
              },
              "from": {
                "file_path": "$file_path",
                "old_string": "$old_string",
                "new_string": "$new_string"
              },
              "to": {
                "path": "$file_path",
                "edits": [
                  {
                    "oldText": "$old_string",
                    "newText": "$new_string"
                  }
                ]
              }
            },
            {
              "when": {
                "has": [
                  "path",
                  "oldText",
                  "newText"
                ],
                "missing": [
                  "edits"
                ]
              },
              "from": {
                "path": "$path",
                "oldText": "$oldText",
                "newText": "$newText"
              },
              "to": {
                "path": "$path",
                "edits": [
                  {
                    "oldText": "$oldText",
                    "newText": "$newText"
                  }
                ]
              }
            }
          ]
        },
        "wiki_get": {
          "required": [
            "lookup"
          ],
          "coercions": [
            {
              "when": {
                "has": [
                  "path"
                ],
                "missing": [
                  "lookup"
                ]
              },
              "from": {
                "path": "$path"
              },
              "to": {
                "lookup": "$path"
              }
            }
          ]
        },
        "wiki_search": {
          "required": [
            "query"
          ],
          "coercions": [
            {
              "when": {
                "has": [
                  "q"
                ],
                "missing": [
                  "query"
                ]
              },
              "from": {
                "q": "$q"
              },
              "to": {
                "query": "$q"
              }
            }
          ]
        },
        "wiki_apply": {
          "required": [
            "op"
          ],
          "coercions": [
            {
              "when": {
                "has": [
                  "sourceId"
                ],
                "missing": [
                  "sourceIds"
                ]
              },
              "from": {
                "sourceId": "$sourceId"
              },
              "to": {
                "sourceIds": [
                  "$sourceId"
                ]
              }
            }
          ]
        },
        "dir_list": {
          "required": [
            "node",
            "path"
          ],
          "aliases": [
            "list_dir"
          ],
          "modelGuidance": "Paired-node remote listing only. Example: {\"node\":\"fox-spirit\",\"path\":\"/remote/dir\"}. For local workspace dirs use exec {\"command\":\"ls -la /path\"}. NOT path-only (Cursor list_dir).",
          "coercions": [
            {
              "when": {
                "has": [
                  "directory"
                ],
                "missing": [
                  "path"
                ]
              },
              "from": {
                "directory": "$directory"
              },
              "to": {
                "path": "$directory"
              }
            },
            {
              "when": {
                "has": [
                  "target_directory"
                ],
                "missing": [
                  "path"
                ]
              },
              "from": {
                "target_directory": "$target_directory"
              },
              "to": {
                "path": "$target_directory"
              }
            }
          ]
        },
        "apply_patch": {
          "required": [
            "input"
          ],
          "aliases": [
            "apply_patch",
            "applypatch",
            "Apply Patch"
          ],
          "modelGuidance": "Example: {\"input\":\"*** Begin Patch\\n*** Update File: path\\n...\"}. NOT patch (Cursor Apply Patch uses patch key).",
          "coercions": [
            {
              "when": {
                "has": [
                  "patch"
                ],
                "missing": [
                  "input"
                ]
              },
              "from": {
                "patch": "$patch"
              },
              "to": {
                "input": "$patch"
              }
            }
          ]
        },
        "read": {
          "required": [
            "path"
          ],
          "aliases": [
            "read_file",
            "Read",
            "read"
          ],
          "modelGuidance": "Example: {\"path\":\"/abs/file.md\",\"offset\":1,\"limit\":80}. NOT target, target_file, or file_path (Cursor read_file shapes).",
          "coercions": [
            {
              "when": {
                "has": [
                  "file_path"
                ],
                "missing": [
                  "path"
                ]
              },
              "from": {
                "file_path": "$file_path"
              },
              "to": {
                "path": "$file_path"
              }
            },
            {
              "when": {
                "has": [
                  "target_file"
                ],
                "missing": [
                  "path"
                ]
              },
              "from": {
                "target_file": "$target_file"
              },
              "to": {
                "path": "$target_file"
              }
            },
            {
              "when": {
                "has": [
                  "target"
                ],
                "missing": [
                  "path"
                ]
              },
              "from": {
                "target": "$target"
              },
              "to": {
                "path": "$target"
              }
            }
          ]
        },
        "write": {
          "required": [
            "path",
            "content"
          ],
          "aliases": [
            "Write",
            "write"
          ],
          "modelGuidance": "Local workspace file write. Example: {\"path\":\"/abs/file.md\",\"content\":\"body\"}. NOT contents or file_path (Cursor Write). Use write for new files; edit for in-place changes.",
          "coercions": [
            {
              "when": {
                "has": [
                  "file_path"
                ],
                "missing": [
                  "path"
                ]
              },
              "from": {
                "file_path": "$file_path"
              },
              "to": {
                "path": "$file_path"
              }
            },
            {
              "when": {
                "has": [
                  "contents"
                ],
                "missing": [
                  "content"
                ]
              },
              "from": {
                "contents": "$contents"
              },
              "to": {
                "content": "$contents"
              }
            }
          ]
        },
        "file_write": {
          "modelGuidance": "Remote paired-node write only when node is set. Example: {\"node\":\"fox-spirit\",\"path\":\"/remote/file.txt\",\"contentBase64\":\"...\"}. For local workspace text use write {\"path\",\"content\"} without node — NOT file_write."
        },
        "exec": {
          "required": [
            "command"
          ],
          "aliases": [
            "run_terminal_cmd",
            "bash",
            "shell",
            "grep",
            "glob",
            "glob_file_search"
          ],
          "modelGuidance": "Gateway shell. Example: {\"command\":\"ls -la /path\"} or {\"command\":\"rg pattern /path\"}. NOT target_pattern (Cursor Glob). For file search prefer command with find/rg, not exec+pattern alone."
        }
      }
    },
    "cursorAgent": {
      "detectHeaders": [
        "user-agent:cursor"
      ],
      "runtimeSurfaces": [
        "ide",
        "cli",
        "api2"
      ],
      "safetyLayer": {
        "description": "Cursor may refuse or suppress schema/tool dumps. L0 api2 often returns long thinking with empty content; 9router guard replaces leaks with a safe reply.",
        "thinkingOnlyHeuristic": true,
        "guardSafeReply": "No callable tools are available for this request. I cannot list or describe internal Cursor tool schemas.",
        "refusalPatterns": [
          "cannot list or describe internal cursor tool schemas",
          "no callable tools are available",
          "read-only tools are available",
          "only have one tool",
          "only\\s+`ask_question`",
          "not in my actual available tools",
          "do not skip any tool.*do not summarize"
        ],
        "notes": [
          "api2 headless: toolCallsCount often 0; Kimi inline tokens appear in thinking text",
          "Declaring bridge tools[] makes upstream more honest (fewer native leaks)",
          "browser_* names in thinking are often hallucination — real browser is IDE bundled MCP",
          "CLI agent has no cursor-ide-browser; WebFetch/WebSearch are product surface, not api2 native"
        ]
      },
      "bundledMcp": {
        "cursor-ide-browser": {
          "surfaces": [
            "ide"
          ],
          "notNative": true,
