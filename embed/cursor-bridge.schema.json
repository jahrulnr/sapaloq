      "expect": {
        "tool": "edit",
        "args": {
          "path": "/tmp/b.txt",
          "old_string": "x",
          "new_string": "y"
        }
      }
    },
    {
      "id": "coerce-apply-patch-openclaw",
      "label": "patch field → apply_patch.input (OpenClaw)",
