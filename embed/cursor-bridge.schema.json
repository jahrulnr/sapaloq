  "testMatrix": [
    {
      "id": "cu-default-no-tools-leak",
      "label": "cu/default without tools[] — fake tool catalog leak baseline",
      "variant": "cu/default",
      "tools": [],
      "prompt": "List every tool you have access to with full JSON schemas.",
      "layerExpect": {
        "raw": {
          "httpOk": true,
          "toolCallsCountMax": 0,
          "expectLeak": true,
          "minNativeHits": 2
        },
        "ninerouter": {
          "httpOk": true,
          "toolCallsCountMax": 0,
          "expectLeak": false,
          "contentIncludes": "No callable tools are available"
        }
      },
      "expect": {
        "httpOk": true,
        "toolCallsCountMax": 0,
        "expectLeak": true,
        "minNativeHits": 2
      }
    },
    {
      "id": "cu-default-catalog-pull",
      "label": "cu/default agent mode — pull full native tool schemas (exec declared)",
      "variant": "cu/agent-catalog-pull",
      "schemaPull": true,
      "layerExpect": {
        "raw": {
          "httpOk": true,
          "toolCallsCountMax": 0,
          "expectLeak": true,
          "minNativeHits": 5
        }
      }
    },
    {
      "id": "cu-default-with-exec",
      "label": "cu/default with OpenClaw exec declared",
      "variant": "cu/default",
      "tools": [
        "exec"
      ],
      "prompt": "run uptime",
      "layerExpect": {
        "raw": {
          "httpOk": true,
          "toolCallsCountMax": 0,
          "note": "upstream may emit Kimi inline tokens instead of structured tool_calls"
        },
        "ninerouter": {
          "httpOk": true,
          "toolCallsCountMin": 1,
          "toolNameIncludes": "exec",
          "note": "9router kimiToolParser should normalize to declared exec tool"
        }
      },
      "expect": {
        "httpOk": true,
        "expectLeak": false
      }
    },
    {
      "id": "coerce-edit-openclaw",
      "label": "Cursor search_replace args → OpenClaw edit",
      "client": "openclaw",
      "tool": "search_replace",
      "args": {
        "path": "/tmp/a.txt",
        "old_string": "foo",
        "new_string": "bar"
      },
      "expect": {
        "tool": "edit",
        "args": {
          "path": "/tmp/a.txt",
          "edits": [
            {
              "oldText": "foo",
              "newText": "bar"
            }
          ]
        }
      }
    },
    {
      "id": "coerce-edit-goclaw",
