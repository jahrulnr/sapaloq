{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sapaloq.local/os.json.schema.json",
  "title": "SapaLOQOSCache",
  "description": "Auto-generated by sapaloq-core detect. Do not edit manually unless debugging. Regenerated on fingerprint mismatch.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "default": "1.0.0"
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "fingerprint": {
      "type": "string",
      "description": "sha256:... hash of stable probe signals"
    },
    "probe": {
      "type": "object",
      "properties": {
        "goos": { "type": "string" },
        "goarch": { "type": "string" },
        "distroId": { "type": "string" },
        "distroVersion": { "type": "string" },
        "prettyName": { "type": "string" },
        "desktop": { "type": "string" },
        "sessionType": { "type": "string", "enum": ["wayland", "x11", "windows", "unknown"] },
        "xdgCurrentDesktop": { "type": "string" },
        "gnomeShellVersion": { "type": "string" }
      },
      "required": ["goos", "distroId", "sessionType"]
    },
    "selectedDriver": {
      "type": "string",
      "enum": ["gnome", "kde", "freedesktop", "windows", "headless"]
    },
    "driverVersion": { "type": "string", "default": "1" },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "notify",
          "notify.watch",
          "screenshot",
          "window.list",
          "window.focus",
          "clipboard",
          "dnd",
          "tray"
        ]
      }
    },
    "paths": {
      "type": "object",
      "properties": {
        "dataDir": { "type": "string" },
        "runtimeDir": { "type": "string" }
      }
    },
    "previousFingerprint": {
      "type": "string",
      "description": "Set when rescan replaced a prior cache"
    }
  },
  "required": ["schemaVersion", "generatedAt", "fingerprint", "probe", "selectedDriver", "capabilities"]
}
