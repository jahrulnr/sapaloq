{
  "schemaVersion": "1.5.0",
  "updatedAt": "2026-06-29T00:00:00Z",
  "updatedBy": "searchwire-web-search",
  "runtime": {
    "dataDir": "~/SapaLOQ",
    "binaryName": "sapaloq-core"
  },
  "platform": {
    "adapter": "auto",
    "detectOrder": [
      "gnome",
      "freedesktop",
      "headless"
    ],
    "allowFallback": true
  },
  "webSearch": {
    "limit": 8,
    "timeoutSec": 20,
    "github": {
      "tokenEnv": "GITHUB_TOKEN"
    }
  },
  "llmBridge": {
    "providerKey": "cursor",
    "providers": [
      {
        "key": "cursor",
        "driver": "cursor-bridge",
        "endpoint": "https://api2.cursor.sh",
        "model": "default",
        "credentialsEnv": "SAPALOQ_CURSOR_TOKEN",
        "requestTimeoutSec": 600,
        "declaredTools": [],
        "maxTokens": 64000,
        "contextWindow": 200000
      },
      {
        "key": "openai",
        "driver": "provider-bridge",
        "endpoint": "https://api.openai.com/v1/chat/completions",
        "model": "gpt-4o-mini",
        "credentialsEnv": "OPENAI_API_KEY",
        "parser": "openai",
        "authScheme": "bearer",
        "contextWindow": 1000000
      },
      {
        "key": "claude",
        "driver": "provider-bridge",
        "endpoint": "https://api.anthropic.com/v1/messages",
        "model": "claude-sonnet-4-5",
        "credentialsEnv": "ANTHROPIC_API_KEY",
        "parser": "claude",
        "authScheme": "x-api-key",
        "apiVersion": "2023-06-01",
        "contextWindow": 200000
      },
      {
        "key": "blackbox",
        "driver": "provider-bridge",
        "endpoint": "https://api.blackbox.ai/chat/completions",
        "model": "blackboxai/anthropic/claude-opus-4.8",
        "credentialsEnv": "BLACKBOX_API_KEY",
        "parser": "openai",
        "contextWindow": 1000000,
        "maxTokens": 131072,
        "maxRetries": 5,
        "stream": true
      },
      {
        "key": "codex",
        "driver": "codex-bridge",
        "model": "gpt-5.5",
        "credentialsEnv": "OPENAI_API_KEY",
        "reasoningEffort": "high",
        "requestTimeoutSec": 600
      },
      {
        "key": "gemini",
        "driver": "gemini-bridge",
        "endpoint": "https://generativelanguage.googleapis.com/v1beta",
        "model": "gemini-flash-latest",
        "credentialsEnv": "GEMINI_API_KEY",
        "reasoningEffort": "low",
        "contextWindow": 1000000,
        "requestTimeoutSec": 600,
        "stream": true
      },
      {
        "key": "llama-cpp-gemma",
        "driver": "llama-cpp",
        "endpoint": "http://127.0.0.1:8080",
        "model": "unsloth/gemma-4-E2B-it-GGUF:Q4_K_XL",
        "reasoningEffort": "low",
        "requestTimeoutSec": 600,
        "stream": true
      }
    ]
  },
  "commands": {
    "triggerChars": [
      "/"
    ],
    "registry": [
      {
        "id": "settings",
        "prefix": "/settings",
        "pattern": "/settings(?:\\s+|$)",
        "label": "Settings",
        "description": "Patch active config.json fields",
        "category": "commands",
        "enabled": true
      },
      {
        "id": "compaction",
        "prefix": "/compaction",
        "pattern": "/compaction(?:\\s+|$)",
        "label": "Compaction",
        "description": "Compact active chat context",
        "category": "commands",
        "enabled": true
      },
      {
        "id": "reset",
        "prefix": "/reset",
        "pattern": "/(reset|clear)(?:\\s+|$)",
        "label": "Reset",
        "description": "Start a fresh active chat session",
        "category": "commands",
        "enabled": true
      },
      {
        "id": "model",
        "prefix": "/model",
        "pattern": "/model(?:\\s+|$)",
        "label": "Model",
        "description": "Switch active provider",
        "category": "commands",
        "enabled": true
      },
      {
        "id": "thinking",
        "prefix": "/thinking",
        "pattern": "/thinking(?:\\s+|$)",
        "label": "Thinking",
        "description": "Set reasoning level",
        "category": "commands",
        "enabled": true
      }
    ]
  },
  "orchestrator": {
    "continuation": {
      "maxInferenceTurns": 128,
      "maxToolCalls": 512,
      "maxParallelTools": 40,
      "maxWallTimeMinutes": 30,
      "maxNoProgressTurns": 10,
      "maxIdenticalToolCalls": 5,
      "maxWaitSeconds": 120
    },
    "compaction": {
      "backgroundThreshold": 0.7,
      "blockingThreshold": 0.88,
      "preserveRecentFraction": 0.3,
      "resumeAfterCompaction": true
    },
    "completion": {
      "trigger": "both",
      "heartbeatIntervalSec": 15,
      "staleAfterSec": 180,
      "requireTerminalEvent": true,
      "notifyUserOnDone": false,
      "speakOnTerminal": true,
      "workerErrorLog": true
    },
    "defaultContextWindowTokens": 131072
  },
  "subAgents": {
    "roles": {
      "planner": {
        "description": "Plan mode: explore, including exec, but do not mutate target artifacts",
        "allowedTools": [
          "read_file",
          "search",
          "list_dir",
          "glob",
          "read_image",
          "web_search",
          "web_fetch",
          "exec",
          "write_plan",
          "read_plan",
          "request_clarification",
          "sapaloq_request_decision",
          "sapaloq_send_steering",
          "wait",
          "sapaloq_cancel_job",
          "sapaloq_stop"
        ],
        "maxTurns": 12,
        "canEditConfig": false,
        "toolPolicy": "read_only"
      },
      "task-runner": {
        "description": "Agent mode: execute the task with full file and host tools",
        "allowedTools": [
          "read_file",
          "search",
          "list_dir",
          "glob",
          "read_image",
          "web_search",
          "web_fetch",
          "exec",
          "write_file",
          "create_file",
          "edit_file",
          "delete_file",
          "read_plan",
          "sapaloq_update_task_progress",
          "sapaloq_complete_task",
          "sapaloq_fail_task",
          "request_clarification",
          "sapaloq_request_decision",
          "sapaloq_send_steering",
          "wait",
          "sapaloq_cancel_job",
          "sapaloq_stop",
          "desktop_notify"
        ],
        "canEditConfig": false,
        "toolPolicy": "full"
      },
      "scribe": {
        "description": "Append notes only through scribe_write_note",
        "allowedTools": [
          "read_file",
          "search",
          "list_dir",
          "glob",
          "read_image",
          "web_search",
          "web_fetch",
          "scribe_write_note",
          "sapaloq_update_task_progress",
          "sapaloq_complete_task",
          "sapaloq_fail_task",
          "request_clarification",
          "sapaloq_request_decision",
          "sapaloq_send_steering",
          "wait",
          "sapaloq_cancel_job",
          "sapaloq_stop"
        ],
        "maxTurns": 8,
        "canEditConfig": false
      }
    }
  },
  "storage": {
    "paths": [
      {
        "id": "personal-notes",
        "path": "~/Documents/sapaloq/personal/notes.md",
        "mode": "personal",
        "kind": "notes",
        "description": "Personal quick notes"
      },
      {
        "id": "work-inbox",
        "path": "~/Documents/sapaloq/work/inbox.md",
        "mode": "work",
        "kind": "inbox",
        "description": "Work capture inbox"
      },
      {
        "id": "hobby-journal",
        "path": "~/Documents/sapaloq/hobby/journal.md",
        "mode": "hobby",
        "kind": "journal",
        "description": "Hobby journal"
      }
    ],
    "intents": {
      "catat": "personal-notes",
      "catat ini": "personal-notes",
      "work note": "work-inbox",
      "jurnal hobby": "hobby-journal"
    }
  },
  "skills": {
    "enabled": true,
    "dir": "~/SapaLOQ/skills",
    "maxLoadPerTurn": 2,
    "maxBodyLines": 40
  },
  "memory": {
    "prefetchEnabled": true,
    "prefetchConfidenceThreshold": 0.7,
    "hotCacheTtlSeconds": 300
  },
  "prompts": {
    "enabled": true,
    "dir": "~/SapaLOQ/prompts"
  },
  "feedback": {
    "explicitSignalsEnabled": true,
    "maxNegativeSlicesPerTurn": 1
  },
  "vault": {
    "maxLogBytes": 5242880,
    "keepRotatedFiles": 3
  },
  "events": {
    "bus": {
      "socketPath": "~/SapaLOQ/run/sapaloq.sock",
      "walPath": "~/SapaLOQ/state/events.jsonl",
      "replayOnBoot": true
    }
  }
}
